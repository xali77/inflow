# Chain: Base mainnet (default). Base USDC address is hardcoded in lib/usdc.ts;
# viem provides Base's RPC + explorer, so no Base env vars are required.

# Privy (dashboard.privy.io)
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_ID=                       # same app id, server-side alias; defaults to NEXT_PUBLIC_PRIVY_APP_ID
NEXT_PUBLIC_PRIVY_CLIENT_ID=        # optional; App settings → Clients
PRIVY_APP_SECRET=                   # server-only; never NEXT_PUBLIC
PRIVY_AUTHORIZATION_PRIVATE_KEY=    # server-only; for server-authorized wallet actions (Privy Earn)
PRIVY_SIGNER_ID=                    # signer/key quorum id users grant; public id, not the private key
NEXT_PUBLIC_PRIVY_SIGNER_ID=        # optional alias for older client-only signer flows

# World ID 4.0 (developer.world.org → your app)
NEXT_PUBLIC_WLD_APP_ID=             # app_…
NEXT_PUBLIC_WLD_RP_ID=              # rp_…  (from "Enable World ID 4.0")
WLD_RP_SIGNING_KEY=                 # server-only secret; signs verification requests
NEXT_PUBLIC_WLD_ACTION=verify-human
NEXT_PUBLIC_WLD_ENV=staging         # "staging" for the simulator; "production" for live

# Privy Earn (GROW) — Morpho USDC vault id from Privy Dashboard → Earn
NEXT_PUBLIC_GROW_VAULT_ID=

# Laso (cards). Payment comes from each user's Privy embedded wallet via the
# Privy Wallet API (uses PRIVY_APP_SECRET + PRIVY_AUTHORIZATION_PRIVATE_KEY +
# PRIVY_SIGNER_ID).
# No server wallet key. Optional API base override:
LASO_BASE_URL=https://laso.finance

# Transak on/off-ramp (server-only; from Transak partner dashboard)
TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_ENV=STAGING                  # STAGING or PRODUCTION
TRANSAK_REFERRER_DOMAIN=             # optional; must match a domain whitelisted in Transak

# FlowPool lending (Base Sepolia). Deploy contracts/ and set the address.
NEXT_PUBLIC_FLOWPOOL_ADDRESS=
NEXT_PUBLIC_BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
FLOWPOOL_SIGNER_KEY=                  # server-only; contract termsSigner key

# Supabase (optional; falls back to local .data/store.json)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Arc testnet — optional secondary chain. Leave commented for Base-only.
# NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
# NEXT_PUBLIC_ARC_CHAIN_ID=5042002
# NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
