NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# World ID 4.0 (developer.world.org → your app)
NEXT_PUBLIC_WLD_APP_ID=          # app_… (public)
NEXT_PUBLIC_WLD_RP_ID=           # rp_…  (public; from "Enable World ID 4.0" / RP registration)
WLD_RP_SIGNING_KEY=              # server-only secret; signs verification requests. Never NEXT_PUBLIC.
NEXT_PUBLIC_WLD_ACTION=verify-human
NEXT_PUBLIC_WLD_ENV=staging        # "staging" for the simulator; "production" for live

NEXT_PUBLIC_ARC_RPC_URL=
NEXT_PUBLIC_ARC_CHAIN_ID=
NEXT_PUBLIC_ARC_USDC_ADDRESS=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Privy server-side wallet API (build 2: in-app send). Keep these secret —
# never prefix with NEXT_PUBLIC. From dashboard.privy.io → your app → Settings.
PRIVY_APP_SECRET=
# Only needed if you create an authorization (signing) key for the wallet API.
PRIVY_AUTHORIZATION_PRIVATE_KEY=
